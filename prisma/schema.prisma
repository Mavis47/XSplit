// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  fullname String
  email    String @unique
  password String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedExpenses Expense[] @relation("ExpenseOwner")
  paidExpenses  Expense[] @relation("ExpensePaidBy")

  groups Group[]
  memberships GroupMember[]
  expenseSplits ExpenseSplit[]
  notifications Notifications[]
}

model Group {
  id Int @id @default(autoincrement())
  GroupName String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user        User     @relation(fields: [userId], references: [id])

  expenses    Expense[]
  members GroupMember[]
}

model Expense {
  id Int @id @default(autoincrement())

  description String
  amount      Float

  ownerId     Int
  owner        User    @relation("ExpenseOwner", fields: [ownerId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  paidById  Int
  paidBy User @relation("ExpensePaidBy", fields: [paidById], references: [id])

 // NULL = Personal Expense
  groupId  Int?
  group   Group?    @relation(fields: [groupId], references: [id])

  splitType SplitType

  splits       ExpenseSplit[]

}

model ExpenseSplit {
  id          String @id @default(cuid())

  expenseId   Int
  userId      Int

  share       Float

  expense      Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user         User    @relation(fields: [userId], references: [id])
}

// Many to many
model GroupMember {
  id        String @id @default(cuid())

  groupId   Int
  userId    Int

  isAdmin   Boolean  @default(false)

  group      Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Notifications {
  id        String @id @default(cuid())
  userId    Int
  message   String
  isRead    Boolean @default(false)
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
}